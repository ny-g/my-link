rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // [공통 함수]
    // 1. 로그인 여부 확인
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // 2. 본인 여부 확인
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // 3. 문자열 검증 헬퍼 (옵션)
    function isValidString(text, min, max) {
      return text is string && text.size() >= min && text.size() <= max;
    }

    // [users 컬렉션 및 하위 경로]
    match /users/{userId} {
      
      // User 메인 문서: 읽기는 누구나 가능, 쓰기는 본인만
      allow read: if true;
      allow create, update: if isOwner(userId);
      allow delete: if false; // 유저 탈퇴는 보통 보안상 Cloud Functions(Admin) 등에서 안전하게 처리하는 것을 권장합니다.

      // 1. Profile 서브컬렉션
      // 경로: users/{userId}/profile/{documentId}
      match /profile/{documentId} {
        allow read: if true; // 누구나 프로필 조회 가능
        allow create, delete: if isOwner(userId);
        // displayName 필드는 수정 불가하도록 제한 (중복 방지용 고정값)
        allow update: if isOwner(userId) && request.resource.data.displayName == resource.data.displayName;
        
        // [추가 제안] 데이터 유효성 검사 (필요시 주석 해제하여 사용)
        // allow update: if isOwner(userId) 
        //              && isValidString(request.resource.data.displayName, 1, 50)
        //              && request.resource.data.updatedAt == request.time;
      }

      // 2. Links 서브컬렉션
      // 경로: users/{userId}/links/{linkId}
      match /links/{linkId} {
        allow read: if true; // 누구나 링크 목록 조회 가능
        allow update: if isOwner(userId) || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['clicks']));
        allow create, delete: if isOwner(userId);
        
        // [추가 제안] 링크 추가 시 필수 필드 및 길이 검증
        // allow create: if isOwner(userId)
        //              && isValidString(request.resource.data.url, 1, 2048)
        //              && isValidString(request.resource.data.title, 1, 100);
      }
      
      // 3. Settings 서브컬렉션 (비공개 설정) - 누락될 수 있는 부분 제안
      // 경로: users/{userId}/settings/{settingId}
      // 설명: 다크모드 기본값 선호도, 이메일 알림 설정 등 남에게 노출되면 안 되는 데이터
      match /settings/{settingId} {
        allow read, write: if isOwner(userId); // 읽기/쓰기 모두 본인만 가능
      }
    }
    
    // [추가 제안: URL Slug 중복 검사용 컬렉션]
    // 경로: slugs/{slugName}
    // 설명: 사용자가 커스텀 URL(예: mylink.com/@username)을 사용할 때, 
    // 중복을 방지하고 slug 기반으로 사용자를 찾기 위해 맵핑하는 컬렉션
    match /slugs/{slug} {
      allow read: if true; // 누구나 slug가 존재하는지 확인 가능해야 함
      
      // 쓰기는 본인의 uid로 slug를 생성할 때만 가능하도록 제한
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      // 수정이나 삭제는 소유자만 가능
      allow update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
  }
}
